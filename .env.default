# LOCAL_PORT is port in host machine. 
# DOCKER_PORT is port reference by docker app.
NODE_DOCKER_PORT=3011
NODE_PORT=3011
# 1 = HTTP on port 3011 (LAN friendly). 0 = HTTPS on 3011 + HTTP on HTTP_PORT
USE_HTTP=1
HTTP_PORT=3010


# For PostgreSQL server
POSTGIS_VERSION_TAG=14-3.1
POSTGRES_DOCKER_PORT=5432
# For docker-compose, use postgres name in `docker-compose.yml` 
POSTGRES_HOST=postgresql-db
POSTGRES_PORT=32768
POSTGRES_DB=elogbook
POSTGRES_USER=docker
POSTGRES_PASS=docker
ALLOW_IP_RANGE=0.0.0.0/0


## Auth (required — deploy.sh auto-generates JWT_SECRET if empty)
JWT_SECRET=

## For MQTT
MQTT_DOCKER_PORT=1883
MQTT_PORT=1883
MQTT_HOST=mqtt-broker
MQTT_USER=temptrack
MQTT_PASSWORD=changeme_mqtt_please_rotate